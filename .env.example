# ── Trino Direct Connection ────────────────────────────────────────────────────
# Copy this file to .env and fill in your credentials.

TRINO_USER=your.email@paytm.com

# ── Service account for BasicAuthentication ────────────────────────────────────
TRINO_SERVICE_USER=service.account@paytm.com
TRINO_SERVICE_PASSWORD=your_service_password

# ── Overrides (defaults shown — only set if your setup differs) ────────────────
# TRINO_HOST=cdp-trino-query.platform.mypaytm.com
# TRINO_PORT=443
# TRINO_CATALOG=hive
# TRINO_SCHEMA=team_servicesone
# TRINO_TABLE=upi_ai_bot_summary_v3
# TRINO_FETCH_LIMIT=500

# ── TrueFoundry LLM Gateway ────────────────────────────────────────────────────
TFY_API_KEY=your_truefoundry_jwt_token
TFY_BASE_URL=https://tfy.internal.ap-south-1.production.apps.pai.mypaytm.com/api/llm/openai/v1
TFY_MODEL=groq/openai-gpt-oss-120b

# ── Google OAuth ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3011/auth/callback
FRONTEND_URL=http://localhost:3011
JWT_SECRET=change-this-to-a-long-random-string-in-production

# ── Deployment (backend) ─────────────────────────────────────────────────────
# Port the uvicorn backend listens on
BACKEND_PORT=8081
# Comma-separated allowed CORS origins. Use * for dev, restrict for production.
# Example: CORS_ORIGINS=http://your-domain:3011,https://your-domain
CORS_ORIGINS=*

# ── Deployment (frontend) ────────────────────────────────────────────────────
# Port the frontend dev server / serve listens on
FRONTEND_PORT=3011
# API base URL baked into the React build. Set before `npm run build`.
REACT_APP_API_BASE=http://localhost:8081/api

# ── Claude API (optional — enables AI summaries) ───────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
